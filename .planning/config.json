{
  "mode": "yolo",
  "granularity": "coarse",
  "model_profile": "balanced",
  "commit_docs": true,
  "parallelization": true,
  "branching_strategy": "none",
  "quick_branch_template": null,
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": true,
    "nyquist_validation": true,
    "pattern_mapper": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "ai_integration_phase": true,
    "tdd_mode": true,
    "code_review": true,
    "code_review_depth": "standard",
    "ui_review": true,
    "skip_discuss": false,
    "use_worktrees": true,
    "research_before_questions": true
  },
  "intel": {
    "enabled": false
  },
  "graphify": {
    "enabled": false
  },
  "hooks": {
    "context_warnings": true
  },
  "resolve_model_ids": "omit"
}
